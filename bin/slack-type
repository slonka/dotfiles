#!/bin/bash
# Simulates typing into Slack using osascript, character by character
# Slack interprets mrkdwn formatting when typed, but not when pasted
# Usage: slack-type "your *bold* and _italic_ text"
#        slack-type -f file.txt
#        echo "text" | slack-type
# Options:
#   -d SECONDS  delay before typing (default: 3)
#   -f FILE     read text from file

DELAY=3
TEXT=""

while getopts "d:f:" opt; do
    case $opt in
        d) DELAY="$OPTARG" ;;
        f) TEXT=$(cat "$OPTARG") ;;
        *) echo "Usage: slack-type [-d delay] [-f file] [text]" >&2; exit 1 ;;
    esac
done
shift $((OPTIND - 1))

if [ -z "$TEXT" ] && [ $# -gt 0 ]; then
    TEXT="$*"
elif [ -z "$TEXT" ]; then
    TEXT=$(cat)
fi

if [ -z "$TEXT" ]; then
    echo "No text provided" >&2
    exit 1
fi

# Preprocess lists for Slack:
# Slack auto-creates subsequent list items when you press Enter inside a list,
# so only keep the marker (-, *, •, 1.) on the first item and strip markers
# from subsequent items. Add an extra newline after a list to exit list mode.
PROCESSED=""
in_list=false
while IFS= read -r line || [ -n "$line" ]; do
    is_list_item=false
    if [[ "$line" =~ ^[[:space:]]*([-]|[*]|•)[[:space:]] ]]; then
        is_list_item=true
    elif [[ "$line" =~ ^[[:space:]]*[0-9]+\.[[:space:]] ]]; then
        is_list_item=true
    fi

    if $is_list_item; then
        if $in_list; then
            # Strip list marker - Slack adds it automatically
            # Remove leading whitespace, then the marker
            stripped="${line#"${line%%[![:space:]]*}"}"
            stripped="${stripped#- }"
            stripped="${stripped#\* }"
            stripped="${stripped#• }"
            # Strip numbered marker (1. , 2. , etc.)
            if [[ "$stripped" =~ ^[0-9]+\.[[:space:]] ]]; then
                stripped="${stripped#*[0-9]. }"
            fi
            line="$stripped"
        else
            in_list=true
        fi
    else
        if $in_list; then
            # Exiting list - add extra newline to break out of list mode
            PROCESSED="${PROCESSED}"$'\n'
            in_list=false
        fi
    fi
    PROCESSED="${PROCESSED}${line}"$'\n'
done <<< "$TEXT"
# Handle trailing list
if $in_list; then
    PROCESSED="${PROCESSED}"$'\n'
fi
# Remove trailing newline added by loop
PROCESSED="${PROCESSED%$'\n'}"
TEXT="$PROCESSED"

osascript -e "display dialog \"slack-type will start typing in ${DELAY} seconds after you click OK.\nFocus the Slack input field first!\" buttons {\"Cancel\", \"OK\"} default button \"OK\" with title \"slack-type\"" 2>/dev/null
if [ $? -ne 0 ]; then
    echo "Cancelled." >&2
    exit 1
fi

echo "You have ${DELAY} seconds to focus the Slack message input..."
sleep "$DELAY"
echo "Typing..."

osascript - "$TEXT" <<'APPLESCRIPT'
on run argv
    set theText to item 1 of argv
    tell application "System Events"
        repeat with i from 1 to count of theText
            set c to character i of theText
            if c is ASCII character 10 then
                key code 36 using {shift down}
            else
                keystroke c
            end if
            delay 0.015
        end repeat
    end tell
end run
APPLESCRIPT

echo "Done!"
